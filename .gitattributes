# Normalize all text files to LF in the repository
* text=auto eol=lf

# Common source files
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf

# Windows batch files should stay CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.zip  binary
*.pdf  binary